{
  "server": {
    "port": 8787,
    "host": "0.0.0.0",
    "guiToken": ""
  },
  "watcher": {
    "baseUrl": "https://pahe.ink",
    "pollIntervalSeconds": 300,
    "perPage": 10,
    "preferredProviders": ["GD"],
    "preferredQualities": ["720p", "1080p"],
    "preferredCodecs": ["x265", "x264"],
    "preferredSeriesType": "batch",
    "onlyCompleteSeries": true,
    "autoResolve": true
  },
  "bypass": {
    "browserMode": "auto",
    "cdpEnabled": false,
    "cdpUrl": "",
    "initialPageDelaySeconds": 1.5,
    "concurrency": 1,
    "timeoutSeconds": 180,
    "profileDir": "./data/browser-profile",
    "maxRetries": 2,
    "speedUpExclusions": ["oii.la", "linegee.net", "tpi.li", "pahe.plus"],
    "tabPruningWhitelist": ["pahe.plus", "old.pahe.plus", "ouo.io", "ouo.press", "gdflix", "drive.google", "pixeldrain", "pixeldra.in", "teknoasian.com", "spacetica.com", "oii.la", "linegee.net", "tpi.li", "wordcounter.icu", "about:blank"],
    "pruneAdTabs": false,
    "injectOuoScript": false,
    "speedUpPahe": true,
    "removeOuoAds": true,
    "stealth": {
      "engine": "patchright",
      "chromeChannel": "chrome",
      "disableAutomationFlag": true,
      "useStealthUserAgent": true,
      "maskWebdriver": true,
      "blockAdsAndTrackers": true,
      "spoofCanvasFingerprint": false,
      "useNoSandbox": true
    },
    "captcha": {
      "provider": "manual",
      "twoCaptchaApiKey": "",
      "capSolverApiKey": "",
      "flaresolverrUrl": "http://localhost:8191",
      "byparrUrl": "http://localhost:8192",
      "startServicesOnStart": true
    },
    "gdflix": {
      "email": "",
      "password": "",
      "cookies": ""
    },
    "google": {
      "cookies": ""
    }
  },
  "sheets": {
    "serviceAccountKey": "./credentials/google-service-account.json",
    "sheetId": "",
    "tab": "Downloads"
  },
  "sync": {
    "backfillBatchSize": 5,
    "backfillDirection": "older",
    "backfillDeepSync": true,
    "backfillAutoRun": false,
    "backfillIntervalSeconds": 60,
    "deepSyncSweepBatchSize": 20,
    "metadataBackfillSweepBatchSize": 20
  },
  "store": {
    "path": "./data/state.json",
    "sqlitePath": "./data/pahe.db"
  },
  "logging": {
    "level": "info"
  }
}
