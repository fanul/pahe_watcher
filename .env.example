# ─────────────────────────────────────────────────────────────
# pahe-watcher configuration
# Copy this file to `.env` and fill in the values.
# All values here override config/default.json.
# ─────────────────────────────────────────────────────────────

# ── Web GUI ──
PORT=8787
HOST=0.0.0.0
# Optional shared secret to protect the GUI/API (leave blank to disable auth)
GUI_TOKEN=

# ── Watcher target ──
PAHE_BASE_URL=https://pahe.ink
# Poll interval in seconds (how often to check for new posts)
POLL_INTERVAL_SECONDS=300
# How many recent posts to inspect per poll
POLL_PER_PAGE=10
# Which provider labels to auto-resolve (comma separated): GD,1F,MG,VF,TB
PREFERRED_PROVIDERS=GD
# Which quality tiers to resolve: 480p,720p,1080p,2160p (blank = all)
PREFERRED_QUALITIES=720p,1080p

# ── Bypass engine ──
# auto | headless | headful
#   auto = follow the captcha provider: manual -> headful, everything else -> headless
BROWSER_MODE=auto
# Max concurrent bypass jobs
BYPASS_CONCURRENCY=1
# Per-job timeout (seconds)
BYPASS_TIMEOUT_SECONDS=180
# Persistent browser profile dir (keeps gdflix login + warms the Cloudflare fingerprint)
BROWSER_PROFILE_DIR=./data/browser-profile

# ── Stealth (beats ouo.io Cloudflare Turnstile) ──
# patchright = undetected Playwright fork (closes the Runtime.enable leak CF detects). Recommended.
# playwright = stock engine + manual stealth patches (fallback)
BYPASS_STEALTH_ENGINE=patchright
# Browser binary channel: "chrome" uses your real Chrome (best for Turnstile); "chromium" uses the bundled build
BYPASS_CHROME_CHANNEL=chrome

# ── Captcha solving ──
# none | manual | 2captcha | capsolver | flaresolverr | byparr
#   none        -> rely on stealth auto-pass (free, often works with patchright)
#   manual      -> solve in the visible window yourself (auto-selects headful)
#   2captcha    -> pays a Turnstile solver (headless)
#   capsolver   -> pays CapSolver, best Turnstile success (headless)
#   flaresolverr/byparr -> ONLY clear full-page CF interstitials, NOT ouo's in-form Turnstile
CAPTCHA_PROVIDER=manual
TWOCAPTCHA_API_KEY=
CAPSOLVER_API_KEY=

# ── GDFlix login (optional, if account required) ──
GDFLIX_EMAIL=
GDFLIX_PASSWORD=

# ── Google Drive login (optional) ──
# Most "anyone with the link" Drive files need no login at all — this is only
# used when the resolved link hits a Google sign-in wall. Export cookies from
# an already-signed-in Google session (browser cookie-export extension, JSON
# array format) and paste them here, or configure via Settings → Google Drive
# in the web GUI (recommended — same per-domain cookie manager as GDFlix).
GOOGLE_DRIVE_COOKIES=

# ── Google Sheets ──
# Path to the Google service-account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
# Target spreadsheet ID (from the sheet URL)
GOOGLE_SHEET_ID=
# Tab/worksheet name to append rows to
GOOGLE_SHEET_TAB=Downloads

# ── Local sync (SQLite-backed post/job archive) ──
# Path to the SQLite database file
SQLITE_PATH=./data/pahe.db
# How many WP REST pages to process per historical backfill batch (resumable —
# each call picks up where the last one left off, not a full one-shot crawl)
SYNC_BACKFILL_BATCH_SIZE=5
# older = walk toward older posts (page 1, 2, 3, ...); newer = walk toward page 1
SYNC_BACKFILL_DIRECTION=older
# Fetch+parse full content (options/poster/rating/synopsis) per post during
# backfill, not just list title/link/date. Set false to do a fast catalog
# listing pass first, then backfill content depth separately via the sweep.
SYNC_BACKFILL_DEEP_SYNC=true
# Run a backfill batch automatically on a timer (off by default — historical
# sync is opt-in, not something you want silently crawling the whole catalog)
SYNC_BACKFILL_AUTO_RUN=false
SYNC_BACKFILL_INTERVAL_SECONDS=60
# Batch size for the deep-sync sweep (fills in content for posts that were
# only listing-synced so far)
SYNC_DEEPSYNC_SWEEP_BATCH_SIZE=20
# Batch size for the metadata-backfill sweep (fills in year/genre/duration/
# director/creator/actors for posts synced under an older parser version)
SYNC_METADATA_BACKFILL_SWEEP_BATCH_SIZE=20
# Batch size for the series-resync sweep (re-fetches series posts whose title
# claims more seasons than we've confirmed stored — i.e. pahe.ink added a
# newer season to the post after our last sync)
SYNC_SERIES_RESYNC_SWEEP_BATCH_SIZE=10

# ── Dead Link Reporting ──
# Template for the WordPress comment text the GUI prepares when you click
# "Report" on a chip. Placeholders: {postLink} {title} {provider}
# {providerName} {quality} {qualityLabel} {codec}. You still submit the
# comment yourself (semi-automated — the app never posts on your behalf).
DEAD_LINK_REPORT_COMMENT_TEMPLATE=Link: {postLink} – Info: {providerName} {quality} {codec} has been deleted, please add a new one

# ── Logging ──
# debug | info | warn | error
LOG_LEVEL=info
