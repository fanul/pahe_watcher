# ─────────────────────────────────────────────────────────────
# pahe-watcher configuration
# Copy this file to `.env` and fill in the values.
# All values here override config/default.json.
# ─────────────────────────────────────────────────────────────

# ── Web GUI ──
PORT=8787
HOST=0.0.0.0
# Optional shared secret to protect the GUI/API (leave blank to disable auth)
GUI_TOKEN=

# ── Watcher target ──
PAHE_BASE_URL=https://pahe.ink
# Poll interval in seconds (how often to check for new posts)
POLL_INTERVAL_SECONDS=300
# How many recent posts to inspect per poll
POLL_PER_PAGE=10
# Which provider labels to auto-resolve (comma separated): GD,1F,MG,VF,TB
PREFERRED_PROVIDERS=GD
# Which quality tiers to resolve: 480p,720p,1080p,2160p (blank = all)
PREFERRED_QUALITIES=720p,1080p

# ── Bypass engine ──
# headless | headful  (headful is required for MANUAL captcha solving)
BROWSER_MODE=headless
# Max concurrent bypass jobs
BYPASS_CONCURRENCY=1
# Per-job timeout (seconds)
BYPASS_TIMEOUT_SECONDS=180
# Persistent browser profile dir (keeps gdflix login/cookies)
BROWSER_PROFILE_DIR=./data/browser-profile

# ── Captcha solving ──
# manual | 2captcha | none
CAPTCHA_PROVIDER=manual
TWOCAPTCHA_API_KEY=

# ── GDFlix login (optional, if account required) ──
GDFLIX_EMAIL=
GDFLIX_PASSWORD=

# ── Google Sheets ──
# Path to the Google service-account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json
# Target spreadsheet ID (from the sheet URL)
GOOGLE_SHEET_ID=
# Tab/worksheet name to append rows to
GOOGLE_SHEET_TAB=Downloads

# ── Logging ──
# debug | info | warn | error
LOG_LEVEL=info
